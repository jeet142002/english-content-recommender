# TMDB API Keys (required)
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_API_TOKEN=your_tmdb_read_access_token_here

# Optional: OMDB API Key for additional metadata
OMDB_API_KEY=your_omdb_api_key_here

# Catalog/session storage
CATALOG_PATH=data/seeds/english_titles.generated.json
SESSION_STORE_PATH=.tmp/recommender_sessions.json

# Web app server-side proxy target
RECOMMENDER_API_BASE_URL=https://your-app-name.railway.app

# Optional direct browser-to-backend mode. Leave unset for the normal Vercel proxy path.
NEXT_PUBLIC_RECOMMENDER_API_BASE_URL=

# Legacy fallback still supported by the Vercel proxy if already configured.
NEXT_PUBLIC_API_URL=

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://your-vercel-app-name.vercel.app,https://localhost:3000
